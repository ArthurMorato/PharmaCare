{
  "realm": "pharmacare",
  "enabled": true,
  "displayName": "PharmaCare",
  "displayNameHtml": "<strong>PharmaCare</strong>",
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 300,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureResetTimeSeconds": 43200,
  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": [
    "LOGIN",
    "LOGIN_ERROR",
    "REGISTER",
    "REGISTER_ERROR",
    "LOGOUT",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["pt-BR", "en", "es"],
  "defaultLocale": "pt-BR",
  
  "clients": [
    {
      "clientId": "pharmacare-web",
      "name": "PharmaCare Web Application",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3000",
        "https://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "https://localhost:3000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "backchannel.logout.session.required": "true",
        "oauth2.device.authorization.grant.enabled": "false",
        "display.on.consent.screen": "false",
        "login_theme": "pharmacare-theme"
      },
      "defaultClientScopes": [
        "web-origins",
        "role_list",
        "roles",
        "profile",
        "email"
      ]
    },
    {
      "clientId": "pharmacare-backend",
      "name": "PharmaCare Backend Services",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "pharmacare-backend-secret-2024",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:8080/realms/pharmacare/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://localhost:8080"
      ],
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "backchannel.logout.session.required": "true",
        "oauth2.device.authorization.grant.enabled": "false",
        "display.on.consent.screen": "false"
      },
      "defaultClientScopes": [
        "web-origins",
        "role_list",
        "roles",
        "profile",
        "email",
        "microprofile-jwt"
      ],
      "serviceAccountsClient": true
    }
  ],
  
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Administrador completo do sistema"
      },
      {
        "name": "pharmacist",
        "description": "Farmacêutico responsável"
      },
      {
        "name": "cashier",
        "description": "Operador de caixa"
      },
      {
        "name": "stock_manager",
        "description": "Gerente de estoque"
      },
      {
        "name": "reporter",
        "description": "Acesso a relatórios"
      },
      {
        "name": "auditor",
        "description": "Auditor do sistema"
      },
      {
        "name": "customer",
        "description": "Cliente da farmácia"
      }
    ],
    "client": {
      "pharmacare-web": [
        {
          "name": "user",
          "description": "Usuário básico do sistema web"
        }
      ],
      "pharmacare-backend": [
        {
          "name": "service",
          "description": "Serviço interno do backend"
        }
      ]
    }
  },
  
  "groups": [
    {
      "name": "Administração",
      "path": "/Administração",
      "realmRoles": ["admin", "auditor"]
    },
    {
      "name": "Farmácia",
      "path": "/Farmácia",
      "realmRoles": ["pharmacist", "stock_manager"]
    },
    {
      "name": "Operacional",
      "path": "/Operacional",
      "realmRoles": ["cashier", "reporter"]
    },
    {
      "name": "Clientes",
      "path": "/Clientes",
      "realmRoles": ["customer"]
    }
  ],
  
  "users": [
    {
      "username": "admin@pharmacare.com",
      "email": "admin@pharmacare.com",
      "firstName": "Administrador",
      "lastName": "Sistema",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Admin@123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"],
      "groups": ["/Administração"],
      "clientRoles": {
        "pharmacare-web": ["user"],
        "pharmacare-backend": ["service"]
      },
      "attributes": {
        "employeeId": ["001"],
        "branch": ["matriz"],
        "department": ["TI"]
      }
    },
    {
      "username": "farmacia@pharmacare.com",
      "email": "farmacia@pharmacare.com",
      "firstName": "Farmacêutico",
      "lastName": "Responsável",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "Farm@123",
          "temporary": false
        }
      ],
      "realmRoles": ["pharmacist", "stock_manager"],
      "groups": ["/Farmácia"],
      "clientRoles": {
        "pharmacare-web": ["user"]
      },
      "attributes": {
        "employeeId": ["002"],
        "branch": ["matriz"],
        "department": ["Farmácia"],
        "crf": ["12345/SP"]
      }
    }
  ],
  
  "requiredCredentials": ["password"],
  "passwordPolicy": "length(8) and digits(1) and upperCase(1) and lowerCase(1) and specialChars(1)",
  
  "smtpServer": {
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "noreply@pharmacare.com",
    "ssl": false,
    "starttls": true,
    "auth": true,
    "user": "${smtp.username}",
    "password": "${smtp.password}"
  },
  
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self'; frame-ancestors 'self'; object-src 'none';",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  
  "loginTheme": "pharmacare-theme",
  "accountTheme": "pharmacare-theme",
  "adminTheme": "pharmacare-theme",
  "emailTheme": "pharmacare-theme"
}